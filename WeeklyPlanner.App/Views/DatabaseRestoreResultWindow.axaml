<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="WeeklyPlanner.App.Views.DatabaseRestoreResultWindow"
        Title="WeeklyPlanner - Esito ripristino"
        Width="560" Height="300"
        MinWidth="480" MinHeight="260"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
  <Grid RowDefinitions="*,Auto" Margin="22">
    <StackPanel Grid.Row="0" Spacing="12">
      <TextBlock x:Name="TitleText" FontSize="20" FontWeight="SemiBold" />
      <Border x:Name="MessageBorder" Padding="12" CornerRadius="8">
        <TextBlock x:Name="MessageText" TextWrapping="Wrap" />
      </Border>
      <TextBlock x:Name="BackupText"
                 Foreground="{DynamicResource TextSecondaryBrush}"
                 FontSize="11"
                 TextWrapping="Wrap" />
    </StackPanel>
    <Button Grid.Row="1" Content="Chiudi" HorizontalAlignment="Right" Click="OnCloseClick" />
  </Grid>
</Window>
