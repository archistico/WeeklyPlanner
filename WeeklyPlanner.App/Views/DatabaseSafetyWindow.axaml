<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:WeeklyPlanner.App.ViewModels"
        x:Class="WeeklyPlanner.App.Views.DatabaseSafetyWindow"
        Title="WeeklyPlanner - Backup e ripristino"
        Width="920" Height="680"
        MinWidth="760" MinHeight="560"
        WindowStartupLocation="CenterOwner">
  <Grid RowDefinitions="Auto,*,Auto">
    <Border Grid.Row="0" Padding="22,18" Classes="headerBar">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
        <StackPanel Grid.Column="0" Spacing="4">
          <TextBlock Text="Backup, ripristino e integrità"
                     FontSize="20"
                     FontWeight="SemiBold" />
          <TextBlock Text="I backup sono copie SQLite autonome e vengono verificati prima di essere mostrati come ripristinabili."
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     TextWrapping="Wrap" />
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <Button Content="Apri cartella"
                  IsEnabled="{Binding IsNotBusy}"
                  Command="{Binding OpenBackupFolderCommand}" />
          <Button Content="Aggiorna"
                  IsEnabled="{Binding CanCreateBackup}"
                  Command="{Binding RefreshBackupsCommand}" />
          <Button Classes="primary"
                  Content="Crea backup ora"
                  IsEnabled="{Binding CanCreateBackup}"
                  Command="{Binding CreateBackupCommand}" />
        </StackPanel>
      </Grid>
    </Border>

    <ScrollViewer Grid.Row="1"
                  IsEnabled="{Binding IsNotBusy}"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalContentAlignment="Top">
      <StackPanel Margin="22,18,22,36" Spacing="14">
        <Border Classes="card" Padding="12">
          <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="5">
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Database" FontWeight="SemiBold" />
            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding DatabasePath}" TextWrapping="Wrap" />
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Backup" FontWeight="SemiBold" />
            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding BackupDirectory}" TextWrapping="Wrap" />
          </Grid>
        </Border>

        <Border Background="#F6D32D" Padding="10" CornerRadius="8"
                IsVisible="{Binding IsRestoreConfirmationVisible}">
          <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8" RowSpacing="10">
            <TextBlock Grid.Row="0" Grid.ColumnSpan="3"
                       Text="{Binding RestoreConfirmationText}"
                       Foreground="#241F31"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap" />
            <Button Grid.Row="1" Grid.Column="1"
                    Content="Annulla"
                    Command="{Binding CancelRestoreCommand}" />
            <Button Grid.Row="1" Grid.Column="2"
                    Classes="primary"
                    Content="Ripristina e riavvia"
                    Command="{Binding ConfirmRestoreCommand}" />
          </Grid>
        </Border>

        <Border Background="#C01C28" Padding="10" CornerRadius="8"
                IsVisible="{Binding HasError}">
          <TextBlock Text="{Binding ErrorMessage}" Foreground="White" TextWrapping="Wrap" />
        </Border>

        <Border Background="{DynamicResource SurfaceBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                Padding="10"
                CornerRadius="8"
                IsVisible="{Binding HasOperationMessage}">
          <TextBlock Text="{Binding OperationMessage}" TextWrapping="Wrap" />
        </Border>

        <TextBlock Text="Backup disponibili"
                   FontSize="16"
                   FontWeight="SemiBold" />

        <TextBlock Text="Non sono ancora presenti backup manuali."
                   IsVisible="{Binding HasNoBackups}"
                   Foreground="{DynamicResource TextSecondaryBrush}" />

        <ListBox ItemsSource="{Binding Backups}"
                 SelectedItem="{Binding SelectedBackup}"
                 IsEnabled="{Binding IsNotBusy}"
                 MinHeight="260"
                 AutomationProperties.Name="Elenco dei backup disponibili">
          <ListBox.Styles>
            <Style Selector="ListBoxItem">
              <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            </Style>
          </ListBox.Styles>
          <ListBox.ItemTemplate>
            <DataTemplate DataType="vm:DatabaseBackupItemViewModel">
              <Border Padding="12" Margin="0,2" CornerRadius="8"
                      BorderBrush="{DynamicResource BorderBrush}"
                      BorderThickness="1">
                <Grid ColumnDefinitions="2.2*,1.1*,1.1*,0.8*,1.1*" ColumnSpacing="12">
                  <StackPanel Grid.Column="0" Spacing="3">
                    <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding KindText}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="3">
                    <TextBlock Text="Creato" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding CreatedAtText}" />
                  </StackPanel>
                  <StackPanel Grid.Column="2" Spacing="3">
                    <TextBlock Text="Dimensione" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding SizeText}" />
                  </StackPanel>
                  <StackPanel Grid.Column="3" Spacing="3">
                    <TextBlock Text="Schema" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding SchemaVersionText}" />
                  </StackPanel>
                  <StackPanel Grid.Column="4" Spacing="3">
                    <TextBlock Text="Integrità" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding IntegrityText}"
                               IsVisible="{Binding IsValid}"
                               Foreground="{DynamicResource SuccessBrush}"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding IntegrityText}"
                               IsVisible="{Binding HasProblem}"
                               Foreground="{DynamicResource DangerBrush}"
                               FontWeight="SemiBold" />
                    <TextBlock Text="{Binding IntegrityDetails}"
                               FontSize="10"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap" />
                  </StackPanel>
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <Border Classes="card" Padding="12" IsVisible="{Binding HasSelectedBackup}">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
            <StackPanel Grid.Column="0" Spacing="4">
              <TextBlock Text="Backup selezionato" FontWeight="SemiBold" />
              <TextBlock Text="{Binding SelectedBackup.FileName}" TextWrapping="Wrap" />
              <TextBlock Text="{Binding SelectedBackup.IntegrityDetails}"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         TextWrapping="Wrap" />
            </StackPanel>
            <Button Grid.Column="1"
                    Content="Ripristina questo backup"
                    VerticalAlignment="Center"
                    IsEnabled="{Binding CanPrepareRestore}"
                    Command="{Binding BeginRestoreCommand}" />
          </Grid>
        </Border>

        <TextBlock Text="Il ripristino non modifica subito il database: WeeklyPlanner prepara l'operazione e si riavvia. Dopo la chiusura della board, la nuova istanza crea il backup preventivo e sostituisce il file prima di aprire connessioni SQLite."
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   FontSize="11"
                   TextWrapping="Wrap" />

        <!-- Spazio tecnico per rendere completamente raggiungibile l'ultimo contenuto. -->
        <Border Height="64" IsHitTestVisible="False" />
      </StackPanel>
    </ScrollViewer>

    <Border Grid.Row="2" Padding="18,12" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource BorderBrush}">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Grid.Column="0"
                   Text="{Binding OperationMessage}"
                   IsVisible="{Binding IsBusy}"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   VerticalAlignment="Center" />
        <Button Grid.Column="1" Content="Chiudi" IsEnabled="{Binding IsNotBusy}" Click="OnCloseClick" />
      </Grid>
    </Border>
  </Grid>
</Window>
