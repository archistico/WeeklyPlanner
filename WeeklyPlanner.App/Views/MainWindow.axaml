<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:WeeklyPlanner.App.ViewModels"
        x:Class="WeeklyPlanner.App.Views.MainWindow"
        Title="WeeklyPlanner"
        Width="1100" Height="700"
        MinWidth="720" MinHeight="480">

  <DockPanel>
    <Border DockPanel.Dock="Top" Classes="headerBar">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <TextBlock Grid.Column="0" Text="WeeklyPlanner" FontWeight="SemiBold" FontSize="16" />
        <TextBlock Grid.Column="2"
                   Text="{Binding CurrentUserName, StringFormat='Connesso come {0}'}"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   VerticalAlignment="Center" />
      </Grid>
    </Border>

    <Border DockPanel.Dock="Top"
            Background="#F6D32D"
            Padding="12,6"
            IsVisible="{Binding HasStatusMessage}">
      <TextBlock Text="{Binding StatusMessage}" Foreground="#241F31" />
    </Border>

    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
      <ItemsControl x:Name="ColumnsItemsControl" ItemsSource="{Binding Columns}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <StackPanel Orientation="Horizontal" Spacing="12" Margin="18" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>

        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="vm:ColumnViewModel">
            <Border Classes="column" Width="260" DragDrop.AllowDrop="True">
              <DockPanel>
                <TextBlock DockPanel.Dock="Top" Classes="columnHeader" Text="{Binding Name}" />

                <Button DockPanel.Dock="Bottom"
                        Margin="12,6,12,0"
                        HorizontalAlignment="Stretch"
                        Content="+ Aggiungi card"
                        Command="{Binding $parent[Window].DataContext.AddCardCommand}"
                        CommandParameter="{Binding}" />

                <ItemsControl Name="CardsItemsControl"
                              ItemsSource="{Binding Cards}"
                              Margin="12,0"
                              Tag="{Binding}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:CardViewModel">
                      <Border Classes="card"
                              Focusable="True">
                        <StackPanel Spacing="4">
                          <Border Height="14"
                                  Cursor="SizeAll"
                                  Background="Transparent"
                                  IsEnabled="{Binding CanDrag}"
                                  PointerPressed="OnCardDragHandlePointerPressed"
                                  PointerMoved="OnCardDragHandlePointerMoved"
                                  PointerReleased="OnCardDragHandlePointerReleased">
                            <TextBlock Text="⋮⋮⋮"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="10" />
                          </Border>

                          <TextBlock Text="{Binding LockStatusText}"
                                     IsVisible="{Binding HasLockStatus}"
                                     Foreground="#C64600"
                                     FontSize="11"
                                     TextWrapping="Wrap" />

                          <TextBox Text="{Binding Title}"
                                   Background="Transparent"
                                   BorderThickness="0"
                                   FontWeight="Medium"
                                   IsReadOnly="{Binding IsEditorReadOnly}"
                                   GotFocus="OnCardFieldGotFocus"
                                   LostFocus="OnCardFieldLostFocus"
                                   KeyDown="OnCardFieldKeyDown" />

                          <TextBox Text="{Binding Notes}"
                                   Background="Transparent"
                                   BorderThickness="0"
                                   AcceptsReturn="True"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="12"
                                   IsReadOnly="{Binding IsEditorReadOnly}"
                                   GotFocus="OnCardFieldGotFocus"
                                   LostFocus="OnCardFieldLostFocus"
                                   KeyDown="OnCardFieldKeyDown" />

                          <StackPanel Orientation="Horizontal"
                                      HorizontalAlignment="Right"
                                      Spacing="6"
                                      IsVisible="{Binding IsEditing}">
                            <Button Content="Annulla"
                                    Padding="8,4"
                                    Command="{Binding $parent[Window].DataContext.CancelEditCommand}"
                                    CommandParameter="{Binding}" />
                            <Button Classes="primary"
                                    Content="Salva"
                                    Padding="8,4"
                                    IsEnabled="{Binding CanSave}"
                                    Command="{Binding $parent[Window].DataContext.CommitEditCommand}"
                                    CommandParameter="{Binding}" />
                          </StackPanel>

                          <TextBlock Text="{Binding Author, StringFormat='di {0}'}"
                                     FontSize="11"
                                     Foreground="{DynamicResource TextSecondaryBrush}" />
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </DockPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </DockPanel>
</Window>
