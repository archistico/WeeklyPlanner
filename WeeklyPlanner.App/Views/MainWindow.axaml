<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:WeeklyPlanner.App.ViewModels"
        x:Class="WeeklyPlanner.App.Views.MainWindow"
        Title="{Binding WindowTitle}"
        Width="1100" Height="700"
        MinWidth="720" MinHeight="480"
        WindowStartupLocation="CenterScreen">

  <DockPanel>
    <Border DockPanel.Dock="Top" Classes="headerBar">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
          <TextBlock Text="WeeklyPlanner" FontWeight="SemiBold" FontSize="16" />
          <Border Background="#3584E4" CornerRadius="4" Padding="5,1" VerticalAlignment="Center">
            <TextBlock Text="{Binding ApplicationMilestone}" Foreground="White" FontSize="10" FontWeight="SemiBold" />
          </Border>
        </StackPanel>

        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <Border Width="9" Height="9" CornerRadius="5" Background="#2EC27E"
                  IsVisible="{Binding IsOnline}" />
          <Border Width="9" Height="9" CornerRadius="5" Background="#E5A50A"
                  IsVisible="{Binding IsConnectionPending}" />
          <Border Width="9" Height="9" CornerRadius="5" Background="#C01C28"
                  IsVisible="{Binding IsOffline}" />

          <TextBlock Text="{Binding ConnectionStatusText}"
                     FontWeight="SemiBold"
                     VerticalAlignment="Center" />
          <TextBlock Text="{Binding LastSuccessfulSyncText}"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     IsVisible="{Binding HasLastSuccessfulSync}"
                     VerticalAlignment="Center" />
          <TextBlock Text="{Binding ActivityText}"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     IsVisible="{Binding HasActivityText}"
                     VerticalAlignment="Center" />
          <Button Content="Riprova ora"
                  Padding="8,3"
                  IsVisible="{Binding CanRetry}"
                  IsEnabled="{Binding CanRetryNow}"
                  Command="{Binding RetryNowCommand}" />
          <TextBlock Text="{Binding CurrentUserName, StringFormat='Utente: {0}'}"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     VerticalAlignment="Center" />
          <Button Classes="icon"
                  Background="Transparent"
                  ToolTip.Tip="Impostazioni"
                  AutomationProperties.Name="Apri impostazioni"
                  Click="OnOpenSettingsClick">
            <Path Width="14" Height="14" Stretch="Uniform"
                  Fill="{DynamicResource TextSecondaryBrush}"
                  Data="M7,0 L9,0 L9.5,2.1 L11.2,3.1 L13.3,2.5 L14.3,4.2 L12.7,5.7 L12.7,7.3 L14.3,8.8 L13.3,10.5 L11.2,9.9 L9.5,10.9 L9,13 L7,13 L6.5,10.9 L4.8,9.9 L2.7,10.5 L1.7,8.8 L3.3,7.3 L3.3,5.7 L1.7,4.2 L2.7,2.5 L4.8,3.1 L6.5,2.1 Z M8,4.2 A2.3,2.3 0 1 0 8,8.8 A2.3,2.3 0 1 0 8,4.2" />
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <Border DockPanel.Dock="Top"
            Background="#F6D32D"
            Padding="12,6"
            IsVisible="{Binding HasWarningStatusMessage}">
      <TextBlock Text="{Binding StatusMessage}" Foreground="#241F31" TextWrapping="Wrap" />
    </Border>

    <Border DockPanel.Dock="Top"
            Background="#C01C28"
            Padding="12,6"
            IsVisible="{Binding HasErrorStatusMessage}">
      <TextBlock Text="{Binding StatusMessage}" Foreground="White" TextWrapping="Wrap" />
    </Border>

    <ScrollViewer x:Name="BoardScrollViewer"
                  Padding="18"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Disabled"
                  VerticalContentAlignment="Stretch">
      <ItemsControl x:Name="ColumnsItemsControl"
                    ItemsSource="{Binding Columns}"
                    VerticalAlignment="Stretch">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <StackPanel Orientation="Horizontal"
                        Spacing="12"
                        VerticalAlignment="Stretch" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>

        <ItemsControl.ItemTemplate>
          <DataTemplate DataType="vm:ColumnViewModel">
            <Border Classes="column"
                    Width="280"
                    VerticalAlignment="Stretch"
                    ClipToBounds="True"
                    DragDrop.AllowDrop="True"
                    AutomationProperties.Name="{Binding Name}">
              <Grid RowDefinitions="Auto,*">
                <Grid Grid.Row="0"
                      ColumnDefinitions="Auto,Auto,*"
                      ColumnSpacing="6"
                      Margin="12,12,12,6">
                  <TextBlock Grid.Column="0"
                             Classes="columnHeader"
                             Text="{Binding Name}"
                             VerticalAlignment="Center" />
                  <Button Grid.Column="1"
                          Classes="columnAdd"
                          ToolTip.Tip="{Binding Name, StringFormat='Aggiungi una card a {0}'}"
                          AutomationProperties.Name="{Binding Name, StringFormat='Aggiungi una card a {0}'}"
                          IsEnabled="{Binding $parent[Window].DataContext.CanModifyBoard}"
                          Command="{Binding $parent[Window].DataContext.AddCardCommand}"
                          CommandParameter="{Binding}">
                    <StackPanel Orientation="Horizontal" Spacing="2">
                      <TextBlock Text="+"
                                 FontSize="14"
                                 FontWeight="SemiBold"
                                 VerticalAlignment="Center" />
                      <Path Width="11"
                            Height="12"
                            Stretch="Uniform"
                            Stroke="{DynamicResource TextSecondaryBrush}"
                            StrokeThickness="1.25"
                            Data="M1,1 L10,1 L10,12 L1,12 Z M3,4 L8,4 M3,7 L8,7" />
                    </StackPanel>
                  </Button>
                </Grid>

                <ScrollViewer Grid.Row="1"
                              MinHeight="0"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                  <StackPanel Margin="12,0,6,0">
                    <ItemsControl Name="CardsItemsControl"
                                  ItemsSource="{Binding Cards}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:CardViewModel">
                          <Grid>
                            <Border Classes="card"
                                    Focusable="True"
                                    KeyDown="OnCardKeyDown"
                                    AutomationProperties.Name="{Binding Title}"
                                    AutomationProperties.AcceleratorKey="Alt+Frecce"
                                    AutomationProperties.HelpText="Usa Alt più freccia su o giù per riordinare; Alt più freccia sinistra o destra per cambiare colonna.">
                              <StackPanel Spacing="5">
                                <Border Height="20"
                                        Cursor="SizeAll"
                                        Background="Transparent"
                                        IsEnabled="{Binding CanDrag}"
                                        ToolTip.Tip="Trascina la card oppure selezionala con Tab e usa Alt + frecce"
                                        PointerPressed="OnCardDragHandlePointerPressed"
                                        PointerMoved="OnCardDragHandlePointerMoved"
                                        PointerReleased="OnCardDragHandlePointerReleased">
                                  <TextBlock Text="⋮⋮⋮"
                                             HorizontalAlignment="Center"
                                             Foreground="{DynamicResource TextSecondaryBrush}"
                                             FontSize="10" />
                                </Border>

                                <TextBlock Text="{Binding LockStatusText}"
                                           IsVisible="{Binding HasLockStatus}"
                                           Foreground="#C64600"
                                           FontSize="11"
                                           TextWrapping="Wrap" />

                                <TextBlock Text="{Binding SaveStatusText}"
                                           IsVisible="{Binding IsSaving}"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           FontSize="11" />
                                <TextBlock Text="{Binding SaveStatusText}"
                                           IsVisible="{Binding HasSaveError}"
                                           Foreground="{DynamicResource DangerBrush}"
                                           FontSize="11"
                                           TextWrapping="Wrap" />

                                <TextBox Text="{Binding Title}"
                                         MaxLength="{Binding TitleMaxLength}"
                                         Watermark="Titolo della card"
                                         ToolTip.Tip="Clicca per acquisire il lock e modificare la card"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         FontWeight="Medium"
                                         FontSize="15"
                                         IsReadOnly="{Binding IsEditorReadOnly}"
                                         GotFocus="OnCardFieldGotFocus"
                                         LostFocus="OnCardFieldLostFocus"
                                         KeyDown="OnCardFieldKeyDown" />

                                <Grid ColumnDefinitions="*,Auto"
                                      IsVisible="{Binding IsEditing}">
                                  <TextBlock Grid.Column="0"
                                             Text="{Binding TitleValidationMessage}"
                                             IsVisible="{Binding HasTitleValidationError}"
                                             Foreground="{DynamicResource DangerBrush}"
                                             FontSize="11"
                                             TextWrapping="Wrap" />
                                  <TextBlock Grid.Column="1"
                                             Text="{Binding TitleLengthText}"
                                             Foreground="{DynamicResource TextSecondaryBrush}"
                                             FontSize="10"
                                             HorizontalAlignment="Right" />
                                </Grid>

                                <TextBox Text="{Binding Notes}"
                                         Watermark="Note"
                                         ToolTip.Tip="Clicca per acquisire il lock e modificare la card"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         Foreground="{DynamicResource TextSecondaryBrush}"
                                         FontSize="12"
                                         IsReadOnly="{Binding IsEditorReadOnly}"
                                         GotFocus="OnCardFieldGotFocus"
                                         LostFocus="OnCardFieldLostFocus"
                                         KeyDown="OnCardFieldKeyDown" />

                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            Spacing="6"
                                            IsVisible="{Binding IsEditing}">
                                  <Button Content="Annulla"
                                          Padding="8,4"
                                          IsEnabled="{Binding CanCancelEdit}"
                                          Command="{Binding $parent[Window].DataContext.CancelEditCommand}"
                                          CommandParameter="{Binding}" />
                                  <Button Classes="primary"
                                          Content="Salva"
                                          Padding="8,4"
                                          IsEnabled="{Binding CanSave}"
                                          Command="{Binding $parent[Window].DataContext.CommitEditCommand}"
                                          CommandParameter="{Binding}" />
                                </StackPanel>

                                <Border Classes="deleteConfirmation"
                                        IsVisible="{Binding IsDeleteConfirmationVisible}">
                                  <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                                    <TextBlock Grid.Column="0"
                                               Text="Eliminare questa card?"
                                               VerticalAlignment="Center"
                                               TextWrapping="Wrap" />
                                    <Button Grid.Column="1"
                                            Classes="compact"
                                            Content="Annulla"
                                            Command="{Binding $parent[Window].DataContext.CancelDeleteCardCommand}"
                                            CommandParameter="{Binding}" />
                                    <Button Grid.Column="2"
                                            Classes="compact danger"
                                            Content="Elimina"
                                            IsEnabled="{Binding $parent[Window].DataContext.CanModifyBoard}"
                                            Command="{Binding $parent[Window].DataContext.DeleteCardCommand}"
                                            CommandParameter="{Binding}" />
                                  </Grid>
                                </Border>

                                <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                                      ColumnSpacing="4">
                                  <TextBlock Grid.Column="0"
                                             Text="{Binding Author, StringFormat='di {0}'}"
                                             Margin="6,0,0,0"
                                             VerticalAlignment="Center"
                                             FontSize="11"
                                             FontStyle="Italic"
                                             Foreground="{DynamicResource TextSecondaryBrush}" />

                                  <Border Grid.Column="2"
                                          Width="24"
                                          Height="24"
                                          Background="Transparent"
                                          ToolTip.Tip="Card salvata"
                                          AutomationProperties.Name="Card salvata"
                                          IsVisible="{Binding HasSaveSuccess}">
                                    <Path Width="14"
                                          Height="14"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Stretch="Uniform"
                                          Fill="{DynamicResource SuccessBrush}"
                                          Data="M1,1 L11,1 L15,5 L15,15 L1,15 Z M3,2 L10,2 L10,6 L3,6 Z M4,9 L12,9 L12,14 L4,14 Z" />
                                  </Border>

                                  <Button Grid.Column="3"
                                          Classes="icon dangerGhost"
                                          ToolTip.Tip="Elimina la card"
                                          AutomationProperties.Name="Elimina la card"
                                          IsVisible="{Binding ShowDeleteButton}"
                                          IsEnabled="{Binding $parent[Window].DataContext.CanModifyBoard}"
                                          Command="{Binding $parent[Window].DataContext.RequestDeleteCardCommand}"
                                          CommandParameter="{Binding}">
                                    <Path Width="12"
                                          Height="14"
                                          Stretch="Uniform"
                                          Fill="{DynamicResource DangerBrush}"
                                          Data="M3,2 L9,2 L10,4 L12,4 L12,5 L0,5 L0,4 L2,4 Z M2,6 L10,6 L9,14 L3,14 Z M4,7 L5,7 L5,12 L4,12 Z M7,7 L8,7 L8,12 L7,12 Z" />
                                  </Button>
                                </Grid>
                              </StackPanel>
                            </Border>

                            <Border Classes="dropIndicator"
                                    Height="4"
                                    Margin="8,2,8,0"
                                    VerticalAlignment="Top"
                                    IsHitTestVisible="False"
                                    IsVisible="{Binding IsDropBeforeVisible}" />
                            <Border Classes="dropIndicator"
                                    Height="4"
                                    Margin="8,0,8,4"
                                    VerticalAlignment="Bottom"
                                    IsHitTestVisible="False"
                                    IsVisible="{Binding IsDropAfterVisible}" />
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Classes="dropIndicator"
                            Height="4"
                            Margin="8,0,8,6"
                            IsHitTestVisible="False"
                            IsVisible="{Binding IsDropAtEndVisible}" />
                  </StackPanel>
                </ScrollViewer>

              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </DockPanel>
</Window>
