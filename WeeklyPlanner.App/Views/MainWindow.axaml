<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:WeeklyPlanner.App.ViewModels"
        x:Class="WeeklyPlanner.App.Views.MainWindow"
        Title="{Binding WindowTitle}"
        MinWidth="720" MinHeight="480">

  <Window.Resources>
    <DataTemplate x:Key="CardTemplate" DataType="vm:CardViewModel">
      <Grid>
        <Border Classes="card"
                Focusable="True"
                KeyDown="OnCardKeyDown"
                AutomationProperties.Name="{Binding Title}"
                AutomationProperties.AcceleratorKey="Alt+Frecce; Ctrl+Alt+Su/Giù"
                AutomationProperties.HelpText="Trascina la card in qualsiasi cella. Usa Alt più freccia su o giù per riordinarla, Alt più freccia sinistra o destra per cambiarne lo stato e Ctrl più Alt più freccia su o giù per cambiarne la fascia.">
          <StackPanel Spacing="5">
            <Border Height="20"
                    Cursor="SizeAll"
                    Background="Transparent"
                    IsEnabled="{Binding CanDrag}"
                    ToolTip.Tip="Trascina la card in qualsiasi cella; Alt + frecce cambia ordine o stato, Ctrl + Alt + Su/Giù cambia fascia"
                    PointerPressed="OnCardDragHandlePointerPressed"
                    PointerMoved="OnCardDragHandlePointerMoved"
                    PointerReleased="OnCardDragHandlePointerReleased">
              <TextBlock Text="⋮⋮⋮"
                         HorizontalAlignment="Center"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         FontSize="10" />
            </Border>

            <TextBlock Text="{Binding LockStatusText}"
                       IsVisible="{Binding HasLockStatus}"
                       Foreground="#C64600"
                       FontSize="11"
                       TextWrapping="Wrap" />

            <TextBox Text="{Binding Title}"
                     MaxLength="{Binding TitleMaxLength}"
                     Watermark="Titolo della card"
                     ToolTip.Tip="Clicca per acquisire il lock e modificare la card"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="8,4"
                     FontWeight="Medium"
                     FontSize="15"
                     IsReadOnly="{Binding IsEditorReadOnly}"
                     GotFocus="OnCardFieldGotFocus"
                     KeyDown="OnCardFieldKeyDown" />

            <Grid ColumnDefinitions="*,Auto"
                  IsVisible="{Binding IsEditing}">
              <TextBlock Grid.Column="0"
                         Text="{Binding TitleValidationMessage}"
                         IsVisible="{Binding HasTitleValidationError}"
                         Foreground="{DynamicResource DangerBrush}"
                         FontSize="11"
                         TextWrapping="Wrap" />
              <TextBlock Grid.Column="1"
                         Text="{Binding TitleLengthText}"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         FontSize="10"
                         HorizontalAlignment="Right" />
            </Grid>

            <TextBox Text="{Binding Notes}"
                     Watermark="Note"
                     ToolTip.Tip="Clicca per acquisire il lock e modificare la card"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="8,4"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     FontSize="12"
                     IsReadOnly="{Binding IsEditorReadOnly}"
                     GotFocus="OnCardFieldGotFocus"
                     KeyDown="OnCardFieldKeyDown" />

            <Grid IsVisible="{Binding IsEditing}"
                  ColumnDefinitions="Auto,*"
                  RowDefinitions="Auto,Auto"
                  ColumnSpacing="8"
                  RowSpacing="3"
                  Margin="8,2,8,2">
              <TextBlock Grid.Row="0"
                         Grid.Column="0"
                         Text="Priorità"
                         VerticalAlignment="Center"
                         FontSize="11"
                         Foreground="{DynamicResource TextSecondaryBrush}" />
              <ComboBox Grid.Row="0"
                        Grid.Column="1"
                        MinWidth="150"
                        HorizontalAlignment="Stretch"
                        ItemsSource="{Binding PriorityOptions}"
                        SelectedItem="{Binding SelectedPriorityOption}"
                        IsEnabled="{Binding CanEditDraft}"
                        ToolTip.Tip="La priorità e la scadenza vengono salvate insieme a titolo e note"
                        GotFocus="OnCardFieldGotFocus"
                        KeyDown="OnCardFieldKeyDown">
                <ComboBox.ItemTemplate>
                  <DataTemplate DataType="vm:CardPriorityOptionViewModel">
                    <Grid ColumnDefinitions="28,*" ColumnSpacing="6">
                      <Border Grid.Column="0" Classes="priorityCodeBadge">
                        <TextBlock Text="{Binding BadgeText}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   FontSize="10" />
                      </Border>
                      <TextBlock Grid.Column="1"
                                 Text="{Binding DisplayName}"
                                 VerticalAlignment="Center" />
                    </Grid>
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
              <TextBlock Grid.Row="1"
                         Grid.Column="1"
                         Text="{Binding DueStatusText}"
                         IsVisible="{Binding HasDueStatus}"
                         FontSize="10"
                         Foreground="{DynamicResource TextSecondaryBrush}"
                         ToolTip.Tip="{Binding DueExactText}" />
            </Grid>

            <Border Classes="prioritySummary"
                    IsVisible="{Binding IsNotEditing}"
                    ToolTip.Tip="{Binding PriorityToolTipText}"
                    Margin="8,2,8,2"
                    Cursor="Hand"
                    Focusable="True"
                    PointerPressed="OnPrioritySummaryPointerPressed">
              <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="7">
                <Border Grid.Column="0" Classes="priorityCodeBadge">
                  <TextBlock Text="{Binding PriorityBadgeCode}"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             FontWeight="SemiBold"
                             FontSize="10" />
                </Border>
                <TextBlock Grid.Column="1"
                           Text="{Binding PriorityBadgeText}"
                           VerticalAlignment="Center"
                           FontSize="11"
                           FontWeight="Medium" />
                <TextBlock Grid.Column="2"
                           Text="{Binding DueStatusText}"
                           IsVisible="{Binding HasDueStatus}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           FontSize="10"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           ToolTip.Tip="{Binding DueExactText}" />
              </Grid>
            </Border>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="6"
                        IsVisible="{Binding IsEditing}">
              <Button Content="Annulla"
                      Padding="8,4"
                      IsEnabled="{Binding CanCancelEdit}"
                      Command="{Binding $parent[Window].DataContext.CancelEditCommand}"
                      CommandParameter="{Binding}" />
              <Button Classes="primary"
                      Content="Salva"
                      Padding="8,4"
                      IsEnabled="{Binding CanSave}"
                      Command="{Binding $parent[Window].DataContext.CommitEditCommand}"
                      CommandParameter="{Binding}" />
            </StackPanel>

            <Border Classes="deleteConfirmation"
                    IsVisible="{Binding IsDeleteConfirmationVisible}">
              <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                <TextBlock Grid.Column="0"
                           Text="Eliminare questa card?"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" />
                <Button Grid.Column="1"
                        Classes="compact"
                        Content="Annulla"
                        Command="{Binding $parent[Window].DataContext.CancelDeleteCardCommand}"
                        CommandParameter="{Binding}" />
                <Button Grid.Column="2"
                        Classes="compact danger"
                        Content="Elimina"
                        IsEnabled="{Binding $parent[Window].DataContext.CanModifyBoard}"
                        Command="{Binding $parent[Window].DataContext.DeleteCardCommand}"
                        CommandParameter="{Binding}" />
              </Grid>
            </Border>

            <Grid ColumnDefinitions="Auto,*,Auto,Auto"
                  ColumnSpacing="4">
              <TextBlock Grid.Column="0"
                         Text="{Binding Author, StringFormat='di {0}'}"
                         Margin="8,0,0,0"
                         VerticalAlignment="Center"
                         FontSize="11"
                         FontStyle="Italic"
                         Foreground="{DynamicResource TextSecondaryBrush}" />

              <Grid Grid.Column="2">
                <StackPanel Orientation="Horizontal"
                            Spacing="4"
                            VerticalAlignment="Center"
                            IsVisible="{Binding ShowSavedPersistenceState}"
                            ToolTip.Tip="{Binding LastSavedToolTipText}"
                            AutomationProperties.Name="{Binding LastSavedToolTipText}">
                  <Path Width="13"
                        Height="13"
                        Stretch="Uniform"
                        Fill="{DynamicResource SuccessBrush}"
                        Data="M1,1 L11,1 L15,5 L15,15 L1,15 Z M3,2 L10,2 L10,6 L3,6 Z M4,9 L12,9 L12,14 L4,14 Z" />
                  <TextBlock Text="{Binding LastSavedRelativeText}"
                             VerticalAlignment="Center"
                             FontSize="10"
                             Foreground="{DynamicResource SuccessBrush}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            Spacing="4"
                            VerticalAlignment="Center"
                            IsVisible="{Binding ShowDirtyPersistenceState}"
                            ToolTip.Tip="Modifiche presenti nella bozza e non ancora salvate">
                  <TextBlock Text="✎"
                             FontSize="11"
                             Foreground="{DynamicResource AccentBrush}" />
                  <TextBlock Text="Non salvata"
                             VerticalAlignment="Center"
                             FontSize="10"
                             Foreground="{DynamicResource AccentBrush}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            Spacing="4"
                            VerticalAlignment="Center"
                            IsVisible="{Binding ShowSavingPersistenceState}"
                            ToolTip.Tip="Salvataggio in corso">
                  <TextBlock Text="↻"
                             FontSize="12"
                             Foreground="{DynamicResource TextSecondaryBrush}" />
                  <TextBlock Text="Salvataggio…"
                             VerticalAlignment="Center"
                             FontSize="10"
                             Foreground="{DynamicResource TextSecondaryBrush}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            Spacing="4"
                            VerticalAlignment="Center"
                            IsVisible="{Binding ShowErrorPersistenceState}"
                            ToolTip.Tip="{Binding SaveStatusText}"
                            AutomationProperties.Name="{Binding SaveStatusText}">
                  <TextBlock Text="⚠"
                             FontSize="11"
                             Foreground="{DynamicResource DangerBrush}" />
                  <TextBlock Text="Errore"
                             VerticalAlignment="Center"
                             FontSize="10"
                             Foreground="{DynamicResource DangerBrush}" />
                </StackPanel>
              </Grid>

              <Button Grid.Column="3"
                      Classes="icon dangerGhost"
                      ToolTip.Tip="Elimina la card"
                      AutomationProperties.Name="Elimina la card"
                      IsVisible="{Binding ShowDeleteButton}"
                      IsEnabled="{Binding $parent[Window].DataContext.CanModifyBoard}"
                      Command="{Binding $parent[Window].DataContext.RequestDeleteCardCommand}"
                      CommandParameter="{Binding}">
                <Path Width="12"
                      Height="14"
                      Stretch="Uniform"
                      Fill="{DynamicResource DangerBrush}"
                      Data="M3,2 L9,2 L10,4 L12,4 L12,5 L0,5 L0,4 L2,4 Z M2,6 L10,6 L9,14 L3,14 Z M4,7 L5,7 L5,12 L4,12 Z M7,7 L8,7 L8,12 L7,12 Z" />
              </Button>
            </Grid>
          </StackPanel>
        </Border>

        <Border Classes="dropIndicator"
                Height="4"
                Margin="8,2,8,0"
                VerticalAlignment="Top"
                IsHitTestVisible="False"
                IsVisible="{Binding IsDropBeforeVisible}" />
        <Border Classes="dropIndicator"
                Height="4"
                Margin="8,0,8,4"
                VerticalAlignment="Bottom"
                IsHitTestVisible="False"
                IsVisible="{Binding IsDropAfterVisible}" />
      </Grid>
    </DataTemplate>

    <DataTemplate x:Key="SwimlaneCellTemplate" DataType="vm:SwimlaneCellViewModel">
      <Border Classes="swimlaneCell"
              MinHeight="132"
              DragDrop.AllowDrop="True"
              AutomationProperties.Name="{Binding AutomationName}">
        <Grid RowDefinitions="Auto,Auto">
          <ItemsControl Grid.Row="0"
                        Name="CardsItemsControl"
                        ItemsSource="{Binding Cards}"
                        ItemTemplate="{StaticResource CardTemplate}" />

          <Border Grid.Row="1"
                  Classes="dropIndicator"
                  Height="4"
                  Margin="8,2,8,2"
                  IsHitTestVisible="False"
                  IsVisible="{Binding IsDropAtEndVisible}" />
        </Grid>
      </Border>
    </DataTemplate>
  </Window.Resources>

  <DockPanel>
    <Border DockPanel.Dock="Top" Classes="headerBar">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
          <TextBlock Text="WeeklyPlanner" FontWeight="SemiBold" FontSize="16" />
          <Border Background="#3584E4" CornerRadius="4" Padding="5,1" VerticalAlignment="Center">
            <TextBlock Text="{Binding ApplicationMilestone}" Foreground="White" FontSize="10" FontWeight="SemiBold" />
          </Border>
        </StackPanel>

        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <Border Width="9" Height="9" CornerRadius="5" Background="#2EC27E"
                  IsVisible="{Binding IsOnline}" />
          <Border Width="9" Height="9" CornerRadius="5" Background="#E5A50A"
                  IsVisible="{Binding IsConnectionPending}" />
          <Border Width="9" Height="9" CornerRadius="5" Background="#C01C28"
                  IsVisible="{Binding IsOffline}" />

          <TextBlock Text="{Binding ConnectionStatusText}"
                     FontWeight="SemiBold"
                     VerticalAlignment="Center" />
          <TextBlock Text="{Binding LastSuccessfulSyncText}"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     IsVisible="{Binding HasLastSuccessfulSync}"
                     VerticalAlignment="Center" />
          <TextBlock Text="{Binding ActivityText}"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     IsVisible="{Binding HasActivityText}"
                     VerticalAlignment="Center" />
          <Button Content="Riprova ora"
                  Padding="8,3"
                  IsVisible="{Binding CanRetry}"
                  IsEnabled="{Binding CanRetryNow}"
                  Command="{Binding RetryNowCommand}" />
          <TextBlock Text="{Binding CurrentUserName, StringFormat='Utente: {0}'}"
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     VerticalAlignment="Center" />
          <Button Classes="icon"
                  Background="Transparent"
                  ToolTip.Tip="Informazioni e diagnostica"
                  AutomationProperties.Name="Apri informazioni e diagnostica"
                  Click="OnOpenDiagnosticsClick">
            <Path Width="14" Height="14" Stretch="Uniform"
                  Fill="{DynamicResource TextSecondaryBrush}"
                  Data="M7,0 A7,7 0 1 0 7,14 A7,7 0 1 0 7,0 Z M6.25,3.1 L7.75,3.1 L7.75,4.6 L6.25,4.6 Z M6.25,6 L7.75,6 L7.75,11 L6.25,11 Z" />
          </Button>
          <Button Classes="icon"
                  Background="Transparent"
                  ToolTip.Tip="Impostazioni"
                  AutomationProperties.Name="Apri impostazioni"
                  Click="OnOpenSettingsClick">
            <Path Width="14" Height="14" Stretch="Uniform"
                  Fill="{DynamicResource TextSecondaryBrush}"
                  Data="M7,0 L9,0 L9.5,2.1 L11.2,3.1 L13.3,2.5 L14.3,4.2 L12.7,5.7 L12.7,7.3 L14.3,8.8 L13.3,10.5 L11.2,9.9 L9.5,10.9 L9,13 L7,13 L6.5,10.9 L4.8,9.9 L2.7,10.5 L1.7,8.8 L3.3,7.3 L3.3,5.7 L1.7,4.2 L2.7,2.5 L4.8,3.1 L6.5,2.1 Z M8,4.2 A2.3,2.3 0 1 0 8,8.8 A2.3,2.3 0 1 0 8,4.2" />
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <Border DockPanel.Dock="Top"
            Background="#F6D32D"
            Padding="12,6"
            IsVisible="{Binding HasWarningStatusMessage}">
      <TextBlock Text="{Binding StatusMessage}" Foreground="#241F31" TextWrapping="Wrap" />
    </Border>

    <Border DockPanel.Dock="Top"
            Background="#C01C28"
            Padding="12,6"
            IsVisible="{Binding HasErrorStatusMessage}">
      <TextBlock Text="{Binding StatusMessage}" Foreground="White" TextWrapping="Wrap" />
    </Border>

    <ScrollViewer x:Name="BoardScrollViewer"
                  Padding="18"
                  Background="Transparent"
                  HorizontalContentAlignment="Stretch"
                  VerticalContentAlignment="Stretch"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto">
      <Grid MinWidth="1630"
            HorizontalAlignment="Stretch"
            RowDefinitions="Auto,Auto,160">
        <Grid Grid.Row="0" ColumnDefinitions="230,*,*,*,*,*">
          <Border Grid.Column="0" Classes="boardHeaderCell first">
            <TextBlock Classes="columnHeader" Text="TIPOLOGIA" />
          </Border>
          <Border Grid.Column="1" Classes="boardHeaderCell">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Classes="columnHeader" Text="BACKLOG" VerticalAlignment="Center" />
              <Button Grid.Column="1" Classes="columnAdd headerAdd"
                      IsEnabled="{Binding CanModifyBoard}"
                      ToolTip.Tip="Aggiungi una card in Generica / BACKLOG"
                      AutomationProperties.Name="Aggiungi card in BACKLOG"
                      Command="{Binding AddCardCommand}"
                      CommandParameter="{Binding BacklogColumn}">
                <TextBlock Text="+" FontSize="18" FontWeight="SemiBold" />
              </Button>
            </Grid>
          </Border>
          <Border Grid.Column="2" Classes="boardHeaderCell">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Classes="columnHeader" Text="TODO" VerticalAlignment="Center" />
              <Button Grid.Column="1" Classes="columnAdd headerAdd"
                      IsEnabled="{Binding CanModifyBoard}"
                      ToolTip.Tip="Aggiungi una card in Generica / TODO"
                      AutomationProperties.Name="Aggiungi card in TODO"
                      Command="{Binding AddCardCommand}"
                      CommandParameter="{Binding TodoColumn}">
                <TextBlock Text="+" FontSize="18" FontWeight="SemiBold" />
              </Button>
            </Grid>
          </Border>
          <Border Grid.Column="3" Classes="boardHeaderCell">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Classes="columnHeader" Text="IN PROGRESS" VerticalAlignment="Center" />
              <Button Grid.Column="1" Classes="columnAdd headerAdd"
                      IsEnabled="{Binding CanModifyBoard}"
                      ToolTip.Tip="Aggiungi una card in Generica / IN PROGRESS"
                      AutomationProperties.Name="Aggiungi card in IN PROGRESS"
                      Command="{Binding AddCardCommand}"
                      CommandParameter="{Binding InProgressColumn}">
                <TextBlock Text="+" FontSize="18" FontWeight="SemiBold" />
              </Button>
            </Grid>
          </Border>
          <Border Grid.Column="4" Classes="boardHeaderCell">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Classes="columnHeader" Text="TESTING" VerticalAlignment="Center" />
              <Button Grid.Column="1" Classes="columnAdd headerAdd"
                      IsEnabled="{Binding CanModifyBoard}"
                      ToolTip.Tip="Aggiungi una card in Generica / TESTING"
                      AutomationProperties.Name="Aggiungi card in TESTING"
                      Command="{Binding AddCardCommand}"
                      CommandParameter="{Binding TestingColumn}">
                <TextBlock Text="+" FontSize="18" FontWeight="SemiBold" />
              </Button>
            </Grid>
          </Border>
          <Border Grid.Column="5" Classes="boardHeaderCell last">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Grid.Column="0" Classes="columnHeader" Text="DONE" VerticalAlignment="Center" />
              <Button Grid.Column="1" Classes="columnAdd headerAdd"
                      IsEnabled="{Binding CanModifyBoard}"
                      ToolTip.Tip="Aggiungi una card in Generica / DONE"
                      AutomationProperties.Name="Aggiungi card in DONE"
                      Command="{Binding AddCardCommand}"
                      CommandParameter="{Binding DoneColumn}">
                <TextBlock Text="+" FontSize="18" FontWeight="SemiBold" />
              </Button>
            </Grid>
          </Border>
        </Grid>

        <ItemsControl x:Name="SwimlanesItemsControl"
                      Grid.Row="1"
                      HorizontalAlignment="Stretch"
                      ItemsSource="{Binding Swimlanes}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Vertical" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="vm:SwimlaneViewModel">
              <Grid MinWidth="1630"
                    HorizontalAlignment="Stretch"
                    ColumnDefinitions="230,*,*,*,*,*">
                <Border Grid.Column="0"
                        Classes="swimlaneLabel"
                        AutomationProperties.Name="{Binding Name}">
                  <Border BorderBrush="{Binding ColorBrush}"
                          BorderThickness="5,0,0,0"
                          Padding="12,10">
                    <StackPanel Spacing="6" VerticalAlignment="Center">
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <Border Width="11"
                                Height="11"
                                CornerRadius="6"
                                Background="{Binding ColorBrush}"
                                VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Name}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center" />
                      </StackPanel>
                      <TextBlock Text="Inattiva"
                                 IsVisible="{Binding IsInactive}"
                                 Foreground="{DynamicResource TextSecondaryBrush}"
                                 FontSize="10"
                                 FontStyle="Italic" />
                    </StackPanel>
                  </Border>
                </Border>

                <ContentControl Grid.Column="1"
                                Content="{Binding Backlog}"
                                ContentTemplate="{StaticResource SwimlaneCellTemplate}" />
                <ContentControl Grid.Column="2"
                                Content="{Binding Todo}"
                                ContentTemplate="{StaticResource SwimlaneCellTemplate}" />
                <ContentControl Grid.Column="3"
                                Content="{Binding InProgress}"
                                ContentTemplate="{StaticResource SwimlaneCellTemplate}" />
                <ContentControl Grid.Column="4"
                                Content="{Binding Testing}"
                                ContentTemplate="{StaticResource SwimlaneCellTemplate}" />
                <ContentControl Grid.Column="5"
                                Content="{Binding Done}"
                                ContentTemplate="{StaticResource SwimlaneCellTemplate}" />
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Spazio tecnico abbondante per portare interamente l'ultima card sopra la scrollbar orizzontale. -->
        <Border Grid.Row="2"
                Height="160"
                IsHitTestVisible="False" />
      </Grid>
    </ScrollViewer>
  </DockPanel>
</Window>
