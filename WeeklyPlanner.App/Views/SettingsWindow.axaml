<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:WeeklyPlanner.App.ViewModels"
        x:Class="WeeklyPlanner.App.Views.SettingsWindow"
        Title="WeeklyPlanner - Impostazioni"
        Width="620" Height="560"
        MinWidth="540" MinHeight="500"
        WindowStartupLocation="CenterOwner">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Border Padding="24">
      <StackPanel Spacing="14">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Text="Impostazioni" FontSize="20" FontWeight="SemiBold" />
          <Button Grid.Column="1" Classes="icon" Background="Transparent"
                  ToolTip.Tip="Configura board"
                  AutomationProperties.Name="Configura priorità e tipologie della board"
                  Click="OnOpenBoardConfigurationClick">
            <Path Width="14" Height="14" Stretch="Uniform"
                  Fill="{DynamicResource TextSecondaryBrush}"
                  Data="M7,0 L9,0 L9.5,2.1 L11.2,3.1 L13.3,2.5 L14.3,4.2 L12.7,5.7 L12.7,7.3 L14.3,8.8 L13.3,10.5 L11.2,9.9 L9.5,10.9 L9,13 L7,13 L6.5,10.9 L4.8,9.9 L2.7,10.5 L1.7,8.8 L3.3,7.3 L3.3,5.7 L1.7,4.2 L2.7,2.5 L4.8,3.1 L6.5,2.1 Z M8,4.2 A2.3,2.3 0 1 0 8,8.8 A2.3,2.3 0 1 0 8,4.2" />
          </Button>
        </Grid>

        <Border Background="#F6D32D" Padding="10" CornerRadius="8"
                IsVisible="{Binding IsIdentityAndDatabaseBlocked}">
          <TextBlock Text="Nome e database sono temporaneamente bloccati perché una card è in modifica o è in corso un'operazione. Tema e polling restano modificabili."
                     Foreground="#241F31" TextWrapping="Wrap" />
        </Border>

        <StackPanel Spacing="4">
          <TextBlock Text="Il tuo nome" FontWeight="Medium" />
          <TextBox Text="{Binding UserName}"
                   IsEnabled="{Binding CanEditIdentityAndDatabase}"
                   Watermark="Es. Emilie" />
        </StackPanel>

        <StackPanel Spacing="4">
          <TextBlock Text="Database SQLite locale" FontWeight="Medium" />
          <TextBox Text="{Binding DatabasePath}"
                   IsEnabled="{Binding CanEditIdentityAndDatabase}" />
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Button Classes="compact" Content="Apri cartella database"
                    Command="{Binding OpenDatabaseFolderCommand}" />
            <Button Classes="compact" Content="Apri dati applicativi"
                    Command="{Binding OpenApplicationDataFolderCommand}" />
          </StackPanel>
          <TextBlock Text="Il cambio del database viene applicato al successivo avvio."
                     Foreground="{DynamicResource TextSecondaryBrush}"
                     FontSize="11" />
        </StackPanel>

        <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
          <StackPanel Grid.Column="0" Spacing="4">
            <TextBlock Text="Polling (secondi)" FontWeight="Medium" />
            <NumericUpDown Value="{Binding PollingIntervalSeconds}"
                           Minimum="3" Maximum="60" />
          </StackPanel>
          <StackPanel Grid.Column="1" Spacing="4">
            <TextBlock Text="Tema" FontWeight="Medium" />
            <ComboBox ItemsSource="{Binding ThemeOptions}"
                      SelectedItem="{Binding SelectedThemeOption}">
              <ComboBox.ItemTemplate>
                <DataTemplate DataType="vm:ThemePreferenceOption">
                  <TextBlock Text="{Binding DisplayName}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </StackPanel>
        </Grid>

        <TextBlock Text="{Binding InformationMessage}"
                   IsVisible="{Binding HasInformationMessage}"
                   Foreground="{DynamicResource SuccessBrush}"
                   TextWrapping="Wrap" />
        <TextBlock Text="{Binding ValidationMessage}"
                   IsVisible="{Binding HasValidationMessage}"
                   Foreground="{DynamicResource DangerBrush}"
                   TextWrapping="Wrap" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
          <Button Content="Annulla" Click="OnCancelClick" />
          <Button Classes="primary" Content="Salva"
                  Command="{Binding SaveCommand}" />
        </StackPanel>
      </StackPanel>
    </Border>
  </ScrollViewer>
</Window>
