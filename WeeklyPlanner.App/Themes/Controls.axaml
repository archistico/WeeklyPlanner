<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        Override leggero sopra FluentTheme per richiamare lo stile GTK4/Libadwaita dell'originale
        (superfici piatte, angoli arrotondati generosi, un solo colore d'accento usato con
        parsimonia) - vedi §7 del documento di progetto per il razionale completo.
    -->

    <Style Selector="Window">
        <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}" />
        <Setter Property="FontFamily" Value="Inter" />
    </Style>

    <!-- Card della board: superficie piatta, bordo sottile, angoli morbidi (~12px, vedi §7.4) -->
    <Style Selector="Border.card">
        <Setter Property="Background" Value="{DynamicResource SurfaceBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="12" />
        <Setter Property="Margin" Value="0,0,0,6" />
    </Style>

    <Style Selector="Border.card:pointerover">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="Border.card:focus">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="2" />
    </Style>

    <Style Selector="Border.dropIndicator">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="CornerRadius" Value="2" />
    </Style>

    <!-- Intestazione di colonna: piatta, testo secondario, nessun rilievo -->
    <Style Selector="TextBlock.columnHeader">
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Margin" Value="0" />
    </Style>

    <Style Selector="Border.column">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="0,0,0,12" />
    </Style>

    <!-- Bottoni: piatti, angoli morbidi (~6-8px, più stretti delle card, vedi §7.4) -->
    <Style Selector="Button">
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="12,6" />
    </Style>

    <Style Selector="Button.primary">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AccentForegroundBrush}" />
    </Style>


    <Style Selector="Button.compact">
        <Setter Property="Padding" Value="7,3" />
        <Setter Property="FontSize" Value="11" />
    </Style>

    <Style Selector="Button.icon">
        <Setter Property="Width" Value="30" />
        <Setter Property="Height" Value="30" />
        <Setter Property="Padding" Value="4" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.columnAdd">
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="Width" Value="38" />
        <Setter Property="Height" Value="26" />
        <Setter Property="Padding" Value="5,2" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.columnAdd.headerAdd">
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="28" />
        <Setter Property="Padding" Value="2,0" />
        <Setter Property="HorizontalAlignment" Value="Right" />
    </Style>

    <Style Selector="Border.prioritySummary">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="7,5" />
    </Style>

    <Style Selector="Border.prioritySummary:focus">
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
    </Style>

    <Style Selector="Border.priorityCodeBadge">
        <Setter Property="MinWidth" Value="24" />
        <Setter Property="Height" Value="20" />
        <Setter Property="Padding" Value="4,1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Background" Value="{DynamicResource SurfaceBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Button.danger">
        <Setter Property="Background" Value="{DynamicResource DangerBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource DangerForegroundBrush}" />
    </Style>

    <Style Selector="Button.dangerGhost">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{DynamicResource DangerBrush}" />
    </Style>

    <Style Selector="Border.deleteConfirmation">
        <Setter Property="Background" Value="{DynamicResource DangerSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="8" />
    </Style>

    <!-- Header piatto della finestra principale, con azione primaria "+" (pattern GNOME headerbar) -->
    <Style Selector="Border.headerBar">
        <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="18,12" />
    </Style>


    <!-- Matrice kanban a swimlane: intestazioni e celle condividono le stesse larghezze. -->
    <Style Selector="Border.boardHeaderCell">
        <Setter Property="Background" Value="{DynamicResource SurfaceBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="0,1,1,1" />
        <Setter Property="Padding" Value="12,10" />
    </Style>

    <Style Selector="Border.boardHeaderCell.first">
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Border.swimlaneLabel">
        <Setter Property="Background" Value="{DynamicResource SurfaceBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1,0,1,1" />
        <Setter Property="MinHeight" Value="132" />
    </Style>

    <Style Selector="Border.swimlaneCell">
        <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="0,0,1,1" />
        <Setter Property="Padding" Value="8" />
    </Style>

    <Style Selector="Border.swimlaneCell:pointerover">
        <Setter Property="Background" Value="{DynamicResource SurfaceBackgroundBrush}" />
    </Style>
</Styles>
