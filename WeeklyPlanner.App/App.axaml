<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="WeeklyPlanner.App.App"
             RequestedThemeVariant="Default">
    <!--
        RequestedThemeVariant="Default" segue il tema (chiaro/scuro) del sistema operativo,
        coerentemente con il comportamento nativo di Libadwaita sull'originale GTK4 (vedi §7.1
        del documento di progetto).
    -->

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://WeeklyPlanner.App/Themes/Controls.axaml" />
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceInclude x:Key="Light" Source="avares://WeeklyPlanner.App/Themes/Colors.Light.axaml" />
                <ResourceInclude x:Key="Dark" Source="avares://WeeklyPlanner.App/Themes/Colors.Dark.axaml" />
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
