<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="WeeklyPlanner.App.App"
             RequestedThemeVariant="Default">
    <!--
        RequestedThemeVariant="Default" segue il sistema operativo. App.axaml.cs può sostituirlo
        a runtime con Light o Dark in base alla preferenza salvata nelle impostazioni locali.
    -->

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://WeeklyPlanner.App/Themes/Controls.axaml" />
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceInclude x:Key="Light" Source="avares://WeeklyPlanner.App/Themes/Colors.Light.axaml" />
                <ResourceInclude x:Key="Dark" Source="avares://WeeklyPlanner.App/Themes/Colors.Dark.axaml" />
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
